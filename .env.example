# --- Provider selection (optional) -------------------------------------
# anthropic | openai
# When unset: inferred as 'openai' if OPENAI_BASE_URL or OPENAI_API_KEY is
# set, otherwise 'anthropic'.
# KI_LLM_PROVIDER=anthropic

# --- Anthropic ---------------------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-key
# KI_ANTHROPIC_MODEL_ID=claude-sonnet-4-20250514

# --- OpenAI-compatible (works for OpenAI, Ollama, vLLM, LM Studio,
#     OpenRouter, Together, Groq, etc.) ---------------------------------
# Hosted (OpenAI):
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL_ID=gpt-4o-mini
#
# Self-hosted (Ollama default — no key needed):
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL_ID=llama3.1
#
# Self-hosted (vLLM / LM Studio / text-generation-webui):
# OPENAI_BASE_URL=http://localhost:8000/v1
# OPENAI_MODEL_ID=your-model-name

# --- Pipeline ----------------------------------------------------------
# KI_DATA_DIR=.data/indices
# KI_MAX_CONCURRENT=5
# KI_OUTPUT_FORMAT=json   # json | yaml | both
# KI_MARKDOWN_PATH=KNOWLEDGE.md
